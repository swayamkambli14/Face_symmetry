{
  "version": 2,
  "builds": [
    {
      "src": "client/package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "dist" }
    },
    {
      "src": "server/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "cv_engine/*.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    { "src": "/api/python/(.*)", "dest": "cv_engine/analyze.py" },
    { "src": "/api/(.*)", "dest": "server/index.js" },
    { "src": "/(.*)", "dest": "client/dist/$1" }
  ]
}